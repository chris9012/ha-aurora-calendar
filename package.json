{
  "name": "aurora-calendar-card",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "git fetch upstream && git rebase upstream/main && npm run build",
    "push": "git push origin main",
    "update": "npm run sync && npm run push",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1"
  },
  "dependencies": {
    "lit": "^3.0.0",
    "lottie-web": "^5.13.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@vitest/ui": "^2.0.0",
    "happy-dom": "^15.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
